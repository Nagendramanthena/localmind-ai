# ── Ollama Configuration ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# ── Embedding / ONNX Configuration ───────────────────────────
EMBEDDING_MODEL_PATH=./models/onnx
# Provider options: DmlExecutionProvider (Windows GPU), CPUExecutionProvider
ONNX_PROVIDERS=auto

# ── Retrieval Configuration ───────────────────────────────────
FAISS_INDEX_PATH=./data/index
DOCUMENTS_PATH=./data/documents
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Agent Configuration ──────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6
MAX_RETRIES=2

# ── Server Configuration ─────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
